{
  "openapi": "3.0.1",
  "info": {
    "title": "Document Processing API",
    "description": "APIs for document upload, metadata, status, result, and deletion. Supports upload URL generation, paginated document listing, and document lifecycle management.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "{api_base_url}",
      "description": "The base URL for the Document Processing API. Replace {api_base_url} with your actual API base URL.",
      "variables": {
        "api_base_url": {
          "default": "https://api.example.com",
          "description": "Actual base URL of the API"
        }
      }
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/": {
      "get": {
        "summary": "Index",
        "description": "API index or root endpoint.",
        "operationId": "index",
        "tags": ["Document Processing"],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": { "type": "string" }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationError" }
              }
            }
          }
        }
      }
    },
    "/document/generate-upload-url": {
      "post": {
        "summary": "Get Upload Url",
        "description": "Generate a URL for document upload.",
        "operationId": "getUploadUrl",
        "tags": ["Document Processing"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": { "type": "string" }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationError" }
              }
            }
          }
        }
      }
    },
    "/document/upload-metadata": {
      "post": {
        "summary": "Upload Metadata",
        "description": "Submit upload metadata for a document.",
        "operationId": "uploadMetadata",
        "tags": ["Document Processing"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationError" }
              }
            }
          }
        }
      }
    },
    "/documents/status/{model_pipeline_id}": {
      "get": {
        "summary": "Get Documents By Model Pipeline",
        "description": "Fetch all documents linked to a specific model_pipeline_id.",
        "operationId": "getDocumentsByModelPipeline",
        "tags": ["Document Processing"],
        "parameters": [
          {
            "name": "model_pipeline_id",
            "in": "path",
            "required": true,
            "description": "model_pipeline_id",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": { "type": "string" }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationError" }
              }
            }
          }
        }
      }
    },
    "/documents/status/{model_pipeline_id}/paged": {
      "get": {
        "summary": "Get Documents By Model Pipeline Paged",
        "description": "Fetch documents linked to a specific model_pipeline_id with pagination and sorting. Default sorting is by modified_on (updated_on) in descending order.",
        "operationId": "getDocumentsByModelPipelinePaged",
        "tags": ["Document Processing"],
        "parameters": [
          {
            "name": "model_pipeline_id",
            "in": "path",
            "required": true,
            "description": "model_pipeline_id",
            "schema": { "type": "string" }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "schema": { "type": "integer", "minimum": 1, "default": 1 }
          },
          {
            "name": "page_size",
            "in": "query",
            "description": "Number of items per page",
            "schema": { "type": "integer", "minimum": 1, "maximum": 200, "default": 20 }
          },
          {
            "name": "sort_by",
            "in": "query",
            "description": "Sort field",
            "schema": { "type": "string", "default": "modified_on" }
          },
          {
            "name": "sort_dir",
            "in": "query",
            "description": "Sort direction (asc or desc). Default: desc",
            "schema": { "type": "string", "default": "desc" }
          },
          {
            "name": "doc_status",
            "in": "query",
            "description": "Filter by document status",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": { "type": "string" }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationError" }
              }
            }
          }
        }
      }
    },
    "/document/result/{doc_id}": {
      "get": {
        "summary": "Get Document Result",
        "description": "Fetch the processing result of a specific document by doc_id.",
        "operationId": "getDocumentResult",
        "tags": ["Document Processing"],
        "parameters": [
          {
            "name": "doc_id",
            "in": "path",
            "required": true,
            "description": "doc_id",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": { "type": "string" }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationError" }
              }
            }
          }
        }
      }
    },
    "/document/{doc_id}": {
      "delete": {
        "summary": "Delete Document",
        "description": "Delete a document by doc_id.",
        "operationId": "deleteDocument",
        "tags": ["Document Processing"],
        "parameters": [
          {
            "name": "doc_id",
            "in": "path",
            "required": true,
            "description": "doc_id",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": { "type": "string" }
              }
            }
