    "/document/internal-result/{tenant_id}/{doc_id}": {
      "get": {
        "summary": "Get Internal Document Result",
        "description": "Fetch the processing result of a specific document by doc_id.",
        "operationId": "getInternalDocumentResult",
        "tags": ["Document Processing"],
        "parameters": [
          {
            "name": "tenant_id",
            "in": "path",
            "required": true,
            "description": "tenant_id",
            "schema": { "type": "string" }
          },
          {
            "name": "doc_id",
            "in": "path",
            "required": true,
            "description": "doc_id",
            "schema": { "type": "string" }
