              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationError" }
              }
            }
          }
        }
      }
    },
    "/document/result_v2/{doc_id}": {
      "get": {
        "summary": "Get Document Result V2",
        "description": "Fetch the processing result of a specific document by doc_id.",
        "operationId": "getDocumentResultV2",
        "tags": ["Document Processing"],
        "parameters": [
          {
            "name": "doc_id",
            "in": "path",
            "required": true,
            "description": "doc_id",
            "schema": { "type": "string" }
          },
          {
            "name": "req_md",
            "in": "query",
            "description": "Include markdown in response",
            "schema": { "type": "boolean", "default": false }
          },
          {
            "name": "req_word_bb",
            "in": "query",
            "description": "Include word bounding boxes",
            "schema": { "type": "boolean", "default": false }
          },
          {
            "name": "req_extracted_data_bb",
            "in": "query",
            "description": "Include extracted data bounding boxes",
            "schema": { "type": "boolean", "default": false }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": { "type": "string" }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationError" }
              }
            }
          }
        }
      }
    },
    "/classify": {
      "post": {
        "summary": "Classify",
        "description": "Classify document.",
        "operationId": "classify",
        "tags": ["Document Processing"],
        "parameters": [
          {
            "name": "doc_id",
            "in": "query",
            "required": true,
            "description": "doc_id",
