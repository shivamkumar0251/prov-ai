        }
      }
    },
    "/api/v1/users/verify-token": {
      "get": {
        "summary": "Verify JWT Token",
        "description": "Verifies a JWT token and returns the payload if the token is valid.",
        "operationId": "verifyJwtToken",
        "tags": ["User Management"],
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "description": "The JWT token to verify.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Token is valid and payload is returned.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "payload": {
                      "type": "object",
                      "additionalProperties": true
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Token is invalid or expired.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "detail": { "type": "string" }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationError" }
              }
            }
          }
        }
      }
    },
    "/auth/sso_login/{provider}": {
      "get": {
        "summary": "Generic OAuth Login",
        "description": "Redirects the user to the specified OAuth 2.0 authentication page.",
        "operationId": "genericOAuthLogin",
        "tags": ["Authentication"],
        "parameters": [
          {
            "name": "provider",
            "in": "path",
            "required": true,
            "description": "provider",
            "schema": { "type": "string" }
          },
          {
            "name": "type",
            "in": "query",
            "required": false,
            "description": "Flow type (default is 'login')",
            "schema": { "type": "string", "default": "login" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": { "type": "string" }
              }
            }
          },
          "422": {
            "description": "Validation Error",
