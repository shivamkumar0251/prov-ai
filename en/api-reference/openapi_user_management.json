{
  "openapi": "3.0.1",
  "info": {
    "title": "User & Authentication Management API",
    "description": "APIs for user signup, login, administration, password management, JWT verification, and OAuth-based authentication.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "{api_base_url}",
      "description": "The base URL for the User & Authentication Management API. Replace {api_base_url} with your actual API base URL.",
      "variables": {
        "api_base_url": {
          "default": "https://api.example.com",
          "description": "Actual base URL of the API"
        }
      }
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/api/v1/users/signup": {
      "post": {
        "summary": "User Signup",
        "description": "Handles the complete user signup process, including OTP validation, tenant creation, and user creation.",
        "operationId": "userSignup",
        "tags": ["User Management"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "first_name": { "type": "string" },
                  "last_name": { "type": "string" },
                  "email": { "type": "string", "format": "email" },
                  "number": { "type": "string" },
                  "company": { "type": "string" },
                  "password": { "type": "string" },
                  "otp": { "type": "string" }
                },
                "required": ["first_name", "last_name", "email", "number", "company", "password", "otp"],
                "additionalProperties": false
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request (e.g., user exists, domain exists, OTP expired)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "detail": { "type": "string" }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Not Found (e.g., role, app type, or OTP not found)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "detail": { "type": "string" }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationError" }
              }
            }
          }
        }
      }
    },
    "/api/v1/users/generate-email-otp": {
      "post": {
        "summary": "Generate Email OTP",
        "description": "Generates and sends a new One-Time Password (OTP) to the user's email address for verification.",
        "operationId": "generateEmailOtp",
        "tags": ["User Management"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "format": "email" }
                },
                "required": ["email"],
                "additionalProperties": false
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OTP generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request (e.g., OTP already sent recently)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "detail": { "type": "string" }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationError" }
              }
            }
          }
        }
      }
    },
    "/api/v1/users/login": {
      "post": {
        "summary": "User Login",
        "description": "Authenticates a user and returns access and refresh tokens.",
        "operationId": "userLogin",
        "tags": ["User Management"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string" }
                },
                "required": ["email", "password"],
                "additionalProperties": false
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful, tokens returned",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access_token": { "type": "string" },
                    "refresh_token": { "type": "string" },
                    "token_type": { "type": "string" },
                    "access_token_expiry": { "type": "string", "format": "date-time" },
                    "refresh_token_expiry": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid email or password",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "detail": { "type": "string" }
                  }
                }
              }
            }
          },
          "403": {
            "description": "User is not active",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "detail": { "type": "string" }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationError" }
              }
            }
          }
        }
      }
    },
    "/api/v1/users/token/refresh": {
      "post": {
        "summary": "Refresh Access Token",
        "description": "Provides a new access and refresh token in exchange for a valid refresh token.",
        "operationId": "refreshAccessToken",
        "tags": ["User Management"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "refresh_token": { "type": "string" }
                },
                "required": ["refresh_token"],
                "additionalProperties": false
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tokens refreshed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access_token": { "type": "string" },
                    "refresh_token": { "type": "string" },
                    "token_type": { "type": "string" },
                    "access_token_expiry": { "type": "string", "format": "date-time" },
                    "refresh_token_expiry": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid or expired refresh token",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "detail": { "type": "string" }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationError" }
              }
            }
          }
        }
      }
    },
    "/api/v1/users/pending-approval": {
      "get": {
        "summary": "List ADMIN Users Pending Approval",
        "description": "Fetches a list of users with role=ADMIN and status=PENDING_APPROVAL. Only accessible by SUPER_ADMIN.",
        "operationId": "listPendingApprovalAdminUsers",
        "tags": ["User Management"],
        "responses": {
          "200": {
            "description": "List of users pending approval",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": true
                  }
                }
              }
            }
          },
          "403": {
            "description": "Not authorized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "detail": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/users/approve": {
      "post": {
        "summary": "Approve or Reject ADMIN User",
        "description": "Approve or reject an ADMIN user by updating their status. Only accessible by SUPER_ADMIN.",
        "operationId": "approveOrRejectAdminUser",
        "tags": ["User Management"],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "description": "UUID of the user to approve or reject",
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "status",
            "in": "query",
            "required": true,
            "description": "Status for the user",
            "schema": {
              "type": "string",
              "enum": ["ACTIVE", "SUSPENDED", "PENDING_APPROVAL", "REJECTED"]
            }
          },
          {
            "name": "comments",
            "in": "query",
            "required": false,
            "description": "Optional comments/reason when rejecting the user",
            "schema": { "type": "string", "nullable": true }
          }
        ],
        "responses": {
          "200": {
            "description": "User status updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "detail": { "type": "string" }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Not authorized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "detail": { "type": "string" }
                  }
                }
              }
            }
          },
          "404": {
            "description": "User not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "detail": { "type": "string" }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationError" }
              }
            }
          }
        }
      }
    },
    "/api/v1/users/users_list": {
      "post": {
        "summary": "List Users for Tenant (POST)",
        "description": "Returns a list of users for a tenant with filtering and sorting. Accessible by ADMIN and SUPER_ADMIN.",
        "operationId": "listUsersForTenant",
        "tags": ["User Management"],
        "parameters": [
          {
            "name": "sort_by",
            "in": "query",
            "required": false,
            "description": "Field to sort by (default is 'id')",
            "schema": { "type": "string", "nullable": true }
          },
          {
            "name": "sort_order",
            "in": "query",
            "required": true,
            "description": "Sort order: 'desc' for descending, 'asc' for ascending",
            "schema": {
              "type": "string",
              "enum": ["desc", "asc"]
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Number of records to skip",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Maximum number of records to return",
            "schema": { "type": "integer", "default": 20 }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "status": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "email": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "role": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                },
                "additionalProperties": false
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List of users",
            "content": {
              "application/json": {
                "schema": { "type": "string" }
              }
            }
          },
          "403": {
            "description": "Not authorized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "detail": { "type": "string" }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationError" }
              }
            }
          }
        }
      }
    },
    "/api/user/profile": {
      "get": {
        "summary": "Get User Profile",
        "description": "Get the currently authenticated user's profile.",
        "operationId": "getUserProfile",
        "tags": ["User Management"],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "/api/user/{id}": {
      "put": {
        "summary": "Update User",
        "description": "Update user details by user ID. Fields that can be updated: first_name, last_name, status, role_id.",
        "operationId": "updateUser",
        "tags": ["User Management"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "id",
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "first_name": { "type": "string" },
                  "last_name": { "type": "string" },
                  "status": { "type": "string" },
                  "role": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                },
                "additionalProperties": false
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": { "type": "string" }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationError" }
              }
            }
          }
        }
      }
    },
    "/api/v1/users/{id}": {
      "delete": {
        "summary": "Delete user (soft)",
        "description": "Soft-deletes a user by setting status to IN_ACTIVE. Only accessible by ADMIN and SUPER_ADMIN.",
        "operationId": "softDeleteUser",
        "tags": ["User Management"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "id",
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "User deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Not authorized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "detail": { "type": "string" }
                  }
                }
              }
            }
          },
          "404": {
            "description": "User not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "detail": { "type": "string" }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationError" }
              }
            }
          }
        }
      }
    },
    "/api/v1/users/create": {
      "post": {
        "summary": "Create User",
        "description": "Creates a new user within the tenant. Accessible by ADMIN and SUPER_ADMIN.",
        "operationId": "createUser",
        "tags": ["User Management"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "first_name": { "type": "string" },
                  "last_name": { "type": "string" },
                  "email": { "type": "string", "format": "email" },
                  "number": { "type": "string" },
                  "role": { "type": "string" },
                  "password": { "type": "string" }
                },
                "required": ["first_name", "last_name", "email", "number", "role", "password"],
                "additionalProperties": false
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request (e.g., user already exists)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "detail": { "type": "string" }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Not authorized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "detail": { "type": "string" }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationError" }
              }
            }
          }
        }
      }
    },
    "/api/v1/users/forgot-password": {
      "post": {
        "summary": "Send reset link to user email",
        "description": "Initiates the forgot password process by sending a reset link (or token) to the user's email.",
        "operationId": "forgotPassword",
        "tags": ["User Management"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "format": "email" }
                },
                "required": ["email"],
                "additionalProperties": false
              }
            }
          }
        },
        "responses": {
          "200": {
