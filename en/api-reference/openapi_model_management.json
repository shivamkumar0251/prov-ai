{
  "openapi": "3.0.1",
  "info": {
    "title": "Model & Tenant Model Management API",
    "description": "APIs for managing models and tenant-specific models: create, update, delete, get, and list.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "{api_base_url}",
      "description": "The base URL for the Model Management API. Replace {api_base_url} with your actual API base URL.",
      "variables": {
        "api_base_url": {
          "default": "https://api.example.com",
          "description": "Actual base URL of the API"
        }
      }
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/model/create": {
      "post": {
        "summary": "Create Model",
        "description": "Create a new model.",
        "operationId": "createModel",
        "tags": ["Model Management"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": { "type": "string" }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationError" }
              }
            }
          }
        }
      }
    },
    "/model/update/{record_id}": {
      "put": {
        "summary": "Update Model",
        "description": "Update an existing model by record_id.",
        "operationId": "updateModel",
        "tags": ["Model Management"],
        "parameters": [
          {
            "name": "record_id",
            "in": "path",
            "required": true,
            "description": "record_id",
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": { "type": "string" }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationError" }
              }
            }
          }
        }
      }
    },
    "/model/delete/{record_id}": {
      "delete": {
        "summary": "Delete Model",
        "description": "Delete a model by record_id.",
        "operationId": "deleteModel",
        "tags": ["Model Management"],
        "parameters": [
          {
            "name": "record_id",
            "in": "path",
            "required": true,
            "description": "record_id",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": { "type": "string" }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationError" }
              }
            }
          }
        }
      }
    },
    "/model/get": {
      "get": {
        "summary": "Get Model",
        "description": "Get a model by name.",
        "operationId": "getModel",
        "tags": ["Model Management"],
        "parameters": [
          {
            "name": "model_name",
            "in": "query",
            "required": false,
            "description": "model_name",
            "schema": { "type": "string", "nullable": true }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationError" }
              }
            }
          }
        }
      }
    },
    "/model/list": {
      "get": {
        "summary": "List Models",
        "description": "List all models.",
        "operationId": "listModels",
        "tags": ["Model Management"],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": true
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationError" }
              }
            }
          }
        }
      }
    },
    "/tenant/model/create": {
      "post": {
        "summary": "Create Tenant Model",
        "description": "Create a new tenant model.",
        "operationId": "createTenantModel",
        "tags": ["Tenant Model Management"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": { "type": "string" }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationError" }
              }
            }
          }
        }
      }
    },
